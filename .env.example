# 이 파일을 복사해 `.env`로 저장한 뒤 값을 맞춥니다.
#
# API 요청/응답 콘솔 로그 — npm run dev 기본 ON. 프로덕션 빌드에서만 필요 시:
# VITE_API_DEBUG=true
# → 401 응답 시 본문 미리보기·파싱된 code 도 출력(백엔드 수정 후에도 401이면 확인용)
#
# --- 개발(npm run dev) ---
# 브라우저가 API로 직접 붙을 베이스 URL (끝에 / 없음). 비우면 상대 경로(/auth, /api)로만 요청하고,
# Vite가 아래 VITE_DEV_PROXY_TARGET(기본 http://127.0.0.1:5090)으로 프록시합니다.
# → 다른 PC에서 http://개발PC_IP:5173 만 열 때: VITE_API_BASE_URL 을 비우는 방식이 연결 거부를 피하기 쉽습니다.
#
# 프로덕션 빌드에서는 실제 API 베이스 URL 필요. 아래 둘 중 하나만 설정하면 됩니다(동시에 있으면 VITE_API_BASE_URL 우선).
# VITE_API_BASE_URL=https://api.example.com
# VITE_API_URL=https://api.example.com
#
# Vite 전용: 프록시가 백엔드로 넘길 주소 (백엔드가 이 PC의 AxiGate Minimal API 일 때)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:5090
#
# 단일 세션(다른 기기 로그인 시 이전 세션 무효): 백엔드 GET /auth/session 구현 후 true
# 미구현 상태에서 켜면 401 응답으로 로그인 직후 튕길 수 있음.
# VITE_AUTH_SESSION_POLL=true
